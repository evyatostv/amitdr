2:["$","section",null,{"className":"section-space","children":["$","div",null,{"className":"container-main max-w-4xl","children":[["$","$L9",null,{"children":["$","h1",null,{"className":"mb-5 text-3xl font-black text-slate-900","children":"שאלות נפוצות"}]}],["$","$La",null,{"items":[{"q":"איך נקבע תור?","a":"ניתן לקבוע תור דרך עמוד קביעת התורים או בטלפון 03-9775355."},{"q":"מה משך הביקור הראשון?","a":"משך הביקור משתנה לפי המקרה, וברוב המקרים נמשך כ-20-40 דקות כולל מעבר על מסמכים ובניית תכנית טיפול."},{"q":"האם ניתן להגיע עם הפניה ממכבי?","a":"מטופלי מכבי יתקבלו דרך הקופה. בעמוד קביעת תור יש לבחור - קביעת תור למטופלי מכבי."},{"q":"מה להביא לביקור ראשון?","a":"סיכומים רפואיים, בדיקות דם עדכניות, הדמיות ורשימת תרופות.","linkText":"להעלאת מסמכים ומילוי שאלון לפני ביקור - לחצו כאן"},{"q":"האם יש מעקב ארוך טווח?","a":"כן. מעקב נקבע לפי האבחנה, פעילות המחלה והתגובה לטיפול."},{"q":"האם אפשר לקבל חוות דעת שנייה?","a":"כן. ניתן להגיע לחוות דעת שנייה עם כל החומר הרפואי הקיים."},{"q":"איך אפשר ליצור קשר מהיר?","a":"ניתן ליצור קשר בטלפון 03-9775355 או דרך עמוד יצירת קשר באתר."}],"questionnaireUrl":"https://smartclinic.belong.life/signup?community=ae5f69b1bae74aab8ea664addd114954"}]]}]}]
